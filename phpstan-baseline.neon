			identifier: argument.templateType
			count: 1
			path: src/Integrations/Eloquent/TemporalEloquentSerializer.php

		-
			message: '#^Unable to resolve the template type TMakeValue in call to static method Illuminate\\Support\\Collection\<\(int\|string\),mixed\>\:\:make\(\)$#'
